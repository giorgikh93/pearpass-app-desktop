{
  "name": "pearpass-app-desktop",
  "version": "1.6.0-beta.23",
  "description": "PearPass password manager",
  "author": "PearPass",
  "main": "electron/main.cjs",
  "upgrade": "pear://mwni83pzx5575qf8gpqqjqpogafz37egr6uzxruqpsb4rc169fdo",
  "pearRuntime": {
    "upgrade": "pear://mwni83pzx5575qf8gpqqjqpogafz37egr6uzxruqpsb4rc169fdo"
  },
  "build": {
    "productName": "PearPass",
    "appId": "com.pears.pass",
    "icon": "assets/darwin/icon.png",
    "asar": true,
    "files": [
      "electron/**/*",
      "dist/**/*",
      "index.html",
      "index.js",
      "packages/**/*",
      "assets/**/*",
      "src/utils/**/*"
    ],
    "asarUnpack": [
      "packages/pearpass-lib-vault-core/src/**",
      "packages/pearpass-lib-vault-core/node_modules/**",
      "packages/pearpass-utils-password-check/**",
      "packages/pear-apps-utils-validator/**",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/darwin/icon.png",
      "target": "dmg"
    },
    "dmg": {},
    "win": {
      "icon": "assets/win32/icon.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "assets/linux/icon.png",
      "target": "AppImage"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "tetherto",
        "repo": "pearpass-app-desktop"
      }
    ]
  },
  "pear": {
    "name": "pearpass-app-desktop",
    "routes": ".",
    "unrouted": [
      "/packages/pearpass-lib-vault-core/src/worklet/app.js",
      "/subProcess/clipboardCleanup.js"
    ],
    "gui": {
      "backgroundColor": "#1F2430",
      "height": "1024",
      "width": "1440"
    },
    "links": [
      "https://hooks.slack.com/services/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",
      "https://docs.google.com/forms/d/e/1FAIpQLScLltvRe64VzMDRzOVjGtHWZ3KafLC2zzvkEoJfTzJkFd67OA/*"
    ],
    "stage": {
      "entrypoints": [

      ],
      "prefetch": [
        "assets"
      ],
      "ignore": [
        ".github",
        "appling",
        ".git",
        ".gitignore",
        ".husky",
        "e2e",
        "packages",
        "scripts",
        "src",
        "tsconfig.json",
        "eslint.config.js",
        "jest.config.js",
        "flatpak",
        "snapcraft"
      ]
    }
  },
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "test": "jest",
    "build:pear": "lingui extract && lingui compile && tsc",
    "lint:fix": "eslint --fix ./src",
    "lint": "eslint ./src",
    "build:worklet": "node scripts/build.worklet.mjs",
    "build": "node scripts/build.worklet.mjs && tsc && node scripts/bundle-renderer.mjs",
    "bundle:renderer": "node scripts/bundle-renderer.mjs",
    "lingui:extract": "lingui extract",
    "lingui:compile": "lingui compile",
    "update-submodules": "bash scripts/update-submodules.sh",
    "prepare": "husky",
    "postinstall": "node scripts/patch-electron-dock-name.mjs",
    "watch:packages": "nodemon --watch packages --ext js,json --exec \"echo 'Packages changed'\"",
    "electron": "electron .",
    "dev": "concurrently -n \"TypeScript,Bundle,Electron\" -c \"blue,cyan,green\" \"node node_modules/typescript/bin/tsc --watch\" \"node scripts/bundle-renderer.mjs --watch\" \"wait-on dist/renderer.bundle.js && electron .\"",
    "dev:reset": "PEARPASS_DEV_RESET=1 npm run dev",
    "pack": "npm install && npm run build && npm prune --omit=dev && npm install electron --no-save && npx electron-builder --dir && npm install",
    "dist": "npm install && npm run build && npm prune --omit=dev && npm install electron --no-save && npx electron-builder && npm install",
    "dist:mac": "npm install && npm run build && npm prune --omit=dev && npm install electron --no-save && npx electron-builder --mac && mkdir -p out/darwin-arm64/pearpass-app-desktop/app && cp -R dist/mac-arm64/PearPass.app out/darwin-arm64/pearpass-app-desktop/app/ && npm install && npm run pear:build:darwin",
    "dist:win": "npm install && npm run build && npm prune --omit=dev && npm install electron --no-save && npx electron-builder --win && npm install",
    "dist:linux": "npm install && npm run build && npm prune --omit=dev && npm install electron --no-save && npx electron-builder --linux && npm install",
    "dist:snap": "npm install && npm run build && npm prune --omit=dev && npm install electron --no-save && npx electron-builder --linux snap && npm install",
    "dist:flatpak": "npm install && npm run build && npm prune --omit=dev && npm install electron --no-save && npx electron-builder --linux flatpak && npm install",
    "pear:build:darwin": "pear-build --package=./package.json --darwin-arm64-app ./out/darwin-arm64/pearpass-app-desktop --target ../pearpass-app-desktop-$npm_package_version"
  },
  "devDependencies": {
    "@babel/core": "7.26.10",
    "@babel/preset-env": "7.26.9",
    "@babel/preset-react": "7.26.3",
    "@babel/preset-typescript": "^7.28.5",
    "@lingui/cli": "5.1.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vercel/ncc": "0.38.3",
    "babel-jest": "29.7.0",
    "bare-pack": "1.4.8",
    "cmake-pear": "2.0.0",
    "concurrently": "9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-reload": "^2.0.0-alpha.1",
    "esbuild": "^0.24.2",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "nodemon": "^3.0.0",
    "pear-interface": "1.0.0",
    "tether-dev-docs": "file:packages/tether-dev-docs",
    "typescript": "5.9.3",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@lingui/core": "5.1.2",
    "@lingui/format-json": "5.1.2",
    "@lingui/macro": "5.1.2",
    "@lingui/react": "5.1.2",
    "@rive-app/react-canvas": "4.22.1",
    "bare-os": "3.6.2",
    "bare-subprocess": "5.2.1",
    "buffer": "6.0.3",
    "compact-encoding": "2.18.0",
    "dotenv": "17.2.1",
    "electron-updater": "^6.8.3",
    "htm": "3.1.1",
    "jszip": "3.10.1",
    "pear-apps-lib-feedback": "file:packages/pear-apps-lib-feedback",
    "pear-apps-lib-ui-react-hooks": "file:packages/pear-apps-lib-ui-react-hooks",
    "pear-apps-utils-avatar-initials": "file:packages/pear-apps-utils-avatar-initials",
    "pear-apps-utils-date": "file:packages/pear-apps-utils-date",
    "pear-apps-utils-generate-unique-id": "file:packages/pear-apps-utils-generate-unique-id",
    "pear-apps-utils-pattern-search": "file:packages/pear-apps-utils-pattern-search",
    "pear-apps-utils-qr": "file:packages/pear-apps-utils-qr",
    "pear-apps-utils-validator": "file:packages/pear-apps-utils-validator",
    "pear-bridge": "1.2.4",
    "pear-electron": "1.7.25-rc.0",
    "pear-ipc": "6.4.0",
    "pear-run": "1.0.5",
    "pear-runtime": "^0.4.3",
    "pear-runtime-legacy-storage": "^1.0.0",
    "pearpass-lib-constants": "file:packages/pearpass-lib-constants",
    "pearpass-lib-data-export": "file:packages/pearpass-lib-data-export",
    "pearpass-lib-data-import": "file:packages/pearpass-lib-data-import",
    "pearpass-lib-ui-theme-provider": "file:packages/pearpass-lib-ui-theme-provider",
    "pearpass-lib-vault": "file:packages/pearpass-lib-vault",
    "pearpass-lib-vault-core": "file:packages/pearpass-lib-vault-core",
    "pearpass-utils-password-check": "file:packages/pearpass-utils-password-check",
    "pearpass-utils-password-generator": "file:packages/pearpass-utils-password-generator",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "styled-components": "6.1.19"
  }
}
